{
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "install": "bash .cursor/install.sh",
  "start": "bash .cursor/start.sh",
  "terminals": [
    {
      "name": "backend",
      "command": "cd ayunis-core-backend && pnpm run start:dev",
      "ports": [3000]
    },
    {
      "name": "frontend",
      "command": "cd ayunis-core-frontend && VITE_API_BASE_URL=http://localhost:3000/api pnpm exec vite --port 3001 --host",
      "ports": [3001]
    }
  ]
}
