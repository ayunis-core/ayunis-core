{
  "name": "core-backend",
  "version": "2.13.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:deps": "pnpm --filter @ayunis/inference --filter @ayunis/provider-anthropic --filter @ayunis/provider-openai --filter @ayunis/provider-mistral --filter @ayunis/provider-gemini --filter @ayunis/provider-ollama run build",
    "prebuild": "pnpm run build:deps",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "prestart:dev": "pnpm run build:deps",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "deps:check": "dependency-cruiser src --config .dependency-cruiser.cjs --ignore-known",
    "deps:check:strict": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "deps:graph": "dependency-cruiser src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:prod": "docker-compose exec api npx typeorm-ts-node-commonjs",
    "migration:generate:dev": "typeorm-ts-node-commonjs migration:generate -d src/db/datasource.ts",
    "migration:run:dev": "typeorm-ts-node-commonjs migration:run -d src/db/datasource.ts",
    "migration:revert:dev": "typeorm-ts-node-commonjs migration:revert -d src/db/datasource.ts",
    "migration:show:dev": "typeorm-ts-node-commonjs migration:show -d src/db/datasource.ts",
    "migration:generate:prod": "docker-compose exec api npx typeorm-ts-node-commonjs migration:generate -d src/db/datasource.ts",
    "migration:run:prod": "docker-compose exec api npx typeorm-ts-node-commonjs migration:run -d src/db/datasource.ts",
    "migration:revert:prod": "docker-compose exec api npx typeorm-ts-node-commonjs migration:revert -d src/db/datasource.ts",
    "migration:show:prod": "docker-compose exec api npx typeorm-ts-node-commonjs migration:show -d src/db/datasource.ts",
    "migration:sync:dev": "typeorm-ts-node-commonjs schema:sync -d src/db/datasource.ts",
    "migration:drop:dev": "typeorm-ts-node-commonjs schema:drop -d src/db/datasource.ts",
    "bundle-frontend": "bash scripts/bundle-frontend.sh",
    "generate:client": "orval --config ./orval.config.ts",
    "cli:ts": "ts-node -r tsconfig-paths/register src/cli/main.ts",
    "cli": "node -r ./src/config/env-register dist/src/cli/main.js",
    "seed:minimal:ts": "ts-node -r tsconfig-paths/register src/db/scripts/seed-minimal/seed-manager.ts",
    "seed:minimal": "node -r ./src/config/env-register dist/src/db/scripts/seed-minimal/seed-manager.js",
    "seed:clean:ts": "ts-node -r tsconfig-paths/register src/db/scripts/seed-minimal/seed-manager.ts --clean",
    "seed:clean": "node -r ./src/config/env-register dist/src/db/scripts/seed-minimal/seed-manager.js --clean",
    "seed:ts": "pnpm run seed:minimal:ts",
    "seed": "pnpm run seed:minimal"
  },
  "dependencies": {
    "@ayunis/inference": "workspace:*",
    "@ayunis/provider-anthropic": "workspace:*",
    "@ayunis/provider-gemini": "workspace:*",
    "@ayunis/provider-mistral": "workspace:*",
    "@ayunis/provider-ollama": "workspace:*",
    "@ayunis/provider-openai": "workspace:*",
    "@mistralai/mistralai": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@nestjs-cls/transactional": "^3.1.0",
    "@nestjs-cls/transactional-adapter-typeorm": "^1.3.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.27",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "@sentry/nestjs": "^10.63.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.2",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "json-schema-to-ts": "^3.1.1",
    "minio": "^8.0.5",
    "mjml": "^4.7.1",
    "multer": "^2.2.0",
    "nest-commander": "^3.19.1",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.0.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^7.0.5",
    "ollama": "^0.6.3",
    "openai": "^4.104.0",
    "otplib": "^12.0.1",
    "p-limit": "^7.3.0",
    "p-queue": "^9.3.1",
    "papaparse": "^5.5.4",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^25.2.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "safe-regex2": "^5.1.1",
    "sanitize-html": "^2.17.5",
    "tiktoken": "^1.0.22",
    "typeorm": "^0.3.25",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/minio": "^7.1.0",
    "@types/mjml": "^4.7.4",
    "@types/mjml-core": "^5.0.0",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^6.4.17",
    "@types/papaparse": "^5.5.2",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "jszip": "^3.10.1",
    "knip": "^6.24.0",
    "madge": "^8.0.0",
    "orval": "^7.3.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.d.ts",
      "!**/migrations/**",
      "!**/db/datasource.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.record.ts",
      "!**/index.ts",
      "!**/cli/**",
      "!**/testing/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../jest.setup.js"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 20,
        "functions": 24,
        "lines": 27,
        "statements": 27
      }
    }
  }
}
