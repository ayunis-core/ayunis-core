{
  "name": "core-backend",
  "version": "1.29.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "deps:check": "dependency-cruiser src --config .dependency-cruiser.cjs --ignore-known",
    "deps:check:strict": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "deps:graph": "dependency-cruiser src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register -r src/config/env-register ./node_modules/typeorm/cli.js",
    "db:prod": "docker-compose exec api npx typeorm-ts-node-commonjs",
    "migration:generate:dev": "npm run typeorm -- migration:generate -d src/db/datasource.ts",
    "migration:run:dev": "npm run typeorm -- migration:run -d src/db/datasource.ts",
    "migration:revert:dev": "npm run typeorm -- migration:revert -d src/db/datasource.ts",
    "migration:show:dev": "npm run typeorm -- migration:show -d src/db/datasource.ts",
    "migration:generate:prod": "npm run db:prod -- migration:generate -d src/db/datasource.ts",
    "migration:run:prod": "npm run db:prod -- migration:run -d src/db/datasource.ts",
    "migration:revert:prod": "npm run db:prod -- migration:revert -d src/db/datasource.ts",
    "migration:show:prod": "npm run db:prod -- migration:show -d src/db/datasource.ts",
    "migration:sync:dev": "npm run typeorm -- schema:sync -d src/db/datasource.ts",
    "migration:drop:dev": "npm run typeorm -- schema:drop -d src/db/datasource.ts",
    "bundle-frontend": "bash scripts/bundle-frontend.sh",
    "generate:client": "orval --config ./orval.config.ts",
    "cli:ts": "ts-node -r tsconfig-paths/register src/cli/main.ts",
    "cli": "node -r ./src/config/env-register dist/src/cli/main.js",
    "seed:minimal:ts": "ts-node -r tsconfig-paths/register src/db/scripts/seed-minimal.ts",
    "seed:minimal": "node -r ./src/config/env-register dist/src/db/scripts/seed-minimal.js",
    "seed:clean:ts": "ts-node -r tsconfig-paths/register src/db/scripts/seed-minimal.ts --clean",
    "seed:clean": "node -r ./src/config/env-register dist/src/db/scripts/seed-minimal.js --clean",
    "seed:ts": "npm run seed:minimal:ts",
    "seed": "npm run seed:minimal"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@anthropic-ai/sdk": "^0.59.0",
    "@google/genai": "^1.41.0",
    "@mistralai/mistralai": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@nestjs-cls/transactional": "^3.1.0",
    "@nestjs-cls/transactional-adapter-typeorm": "^1.3.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.1.5",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/nestjs": "^10.25.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.14.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.0",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "json-schema-to-ts": "^3.1.1",
    "minio": "^8.0.5",
    "mjml": "^4.7.1",
    "nest-commander": "^3.19.1",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.0.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^7.0.5",
    "ollama": "^0.6.3",
    "openai": "^4.104.0",
    "p-limit": "^7.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^24.37.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.1",
    "tiktoken": "^1.0.22",
    "typeorm": "^0.3.25",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "basic-ftp": ">=5.2.0 <6",
    "protobufjs": ">=7.5.5 <8"
  },
  "overridesNotes": {
    "basic-ftp": "Patches GHSA-5rq4-664w-9x2c (path traversal). Transitive via puppeteer-core → @puppeteer/browsers → proxy-agent → pac-proxy-agent → get-uri. Not reachable in our code (html-document-export.service.ts uses system Chromium via executablePath, never downloads browsers, no proxy config), but blocks the CI security audit. Remove when @puppeteer/browsers bumps get-uri past the vulnerable range — verify with `npm ls basic-ftp` after any puppeteer-core upgrade.",
    "protobufjs": "Patches GHSA-xq3m-2v4x-88gg (arbitrary code execution, fixed in 7.5.5). Transitive via @google/genai. @google/genai declares `^7.5.4`, so this floor stays within its range. Remove when @google/genai's declared range moves past 7.5.5 — verify with `npm ls protobufjs` after any @google/genai upgrade."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/minio": "^7.1.0",
    "@types/mjml": "^4.7.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/sanitize-html": "^2.16.0",
    "better-npm-audit": "^3.11.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "knip": "^5.84.1",
    "madge": "^8.0.0",
    "orval": "^7.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.d.ts",
      "!**/migrations/**",
      "!**/db/datasource.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.record.ts",
      "!**/index.ts",
      "!**/cli/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../jest.setup.js"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 20,
        "functions": 24,
        "lines": 27,
        "statements": 27
      }
    }
  }
}
