# See ./src/config/* for default values
#
# Team members: do NOT copy this file — the dev config (secrets + base
# connection values) is injected from Infisical (`infisical login`, then
# `./dev up`). This file is the template for contributors without Infisical
# access and for production deployments. For local dev, keep connection
# values at their base (slot-0) defaults: ports are derived from
# DEV_PORT_OFFSET at boot (src/config/dev-port-offset.ts).
# Application

# The INTERNAL port of the app inside the container
# You probably do not want to change this
# If you do, you must change the CONTAINER_PORT variable in the root's .env as well
PORT=3000
# If you selfhost and only want your personal org
DISABLE_REGISTRATION=
# Must be set to 'self-hosted'
APP_ENVIRONMENT=self-hosted
# Value in x-admin-token for admin endpoints
# See README for details
ADMIN_TOKEN=
# Optional: Synchronize organisations with external tools
# Check src/common/webhooks/domain/webhook-events/* for webhook payloads
ORG_EVENTS_WEBHOOK_URL=
# Required when ORG_EVENTS_WEBHOOK_URL is set in production. Shared secret used
# to HMAC-SHA256-sign outbound webhook payloads. Receivers must verify the
# X-Webhook-Signature header (Stripe-style: t=<unix>,v1=<hex>) before trusting
# the request body. Outside production a missing secret only logs a warning.
WEBHOOK_SIGNING_SECRET=
# Optional: Report errors/performance/logs to AppSignal (production only).
# APP_REVISION additionally marks the running version (defaults to package.json version).
# APPSIGNAL_APP_NAME overrides the dashboard app name (defaults to ayunis-core).
APPSIGNAL_PUSH_API_KEY=
# Optional, HTTP keep-alive timeout in ms (default 65000). Must exceed the
# idle timeout of YOUR fronting proxy/load balancer, or idle sockets close
# on the Node side first and surface as intermittent 502s.
HTTP_KEEP_ALIVE_TIMEOUT_MS=

# Frontend
# Including 'https://', used for sending invite emails, password reset mails, etc.
FRONTEND_BASEURL=
# Optional
EMAIL_CONFIRM_ENDPOINT=
# Optional
PASSWORD_RESET_ENDPOINT=
# Optional (default '/password/forgot')
FORGOT_PASSWORD_ENDPOINT=
# Optional
INVITE_ACCEPT_ENDPOINT=

# Emails
# For sending transactional emails such as invites, password resets, etc.
# If no values are provided, features behave in a way to not need emails
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_REQUIRE_TLS=

# Legal
# Not relevant for self hosters
TERMS_OF_SERVICE_VERSION=
PRIVACY_POLICY_VERSION=
PROVIDER_OPENAI_LEGAL_VERSION=
PROVIDER_ANTHROPIC_LEGAL_VERSION=
PROVIDER_MISTRAL_LEGAL_VERSION=
PROVIDER_SYNAFORCE_LEGAL_VERSION=

# Auth
# See src/config/authentication.config.ts for default values
# Optional, auth strategy: 'local' (default) or 'cloud'
AUTH_PROVIDER=
# Optional, bcrypt cost factor (default 10)
PASSWORD_HASH_ROUNDS=
# Cloud auth service, only required when AUTH_PROVIDER=cloud
CLOUD_AUTH_API_URL=
CLOUD_AUTH_API_KEY=
# Comma separated list of URLs
CORS_ALLOWED_ORIGINS=http://localhost:5173/,http://localhost:3000
# Optional
COOKIE_SAME_SITE=lax
# Optional
COOKIE_DOMAIN=localhost
# Secret for signing auth cookies. REQUIRED in every environment; the app
# refuses to boot without it. There is no insecure default fallback.
# Generate a secure value with: openssl rand -hex 32
COOKIE_SECRET=
# Controls the Secure attribute on session cookies. Set to false only for
# local http (non-https) setups. REQUIRED to be true in production: the app
# refuses to boot when NODE_ENV=production and COOKIE_SECURE is not "true".
COOKIE_SECURE=true
# Secret for signing logged in user's auth payload. REQUIRED in every
# environment; the app refuses to boot without it. There is no insecure
# default fallback. Generate a secure value with: openssl rand -hex 32
JWT_SECRET=
# Optional
JWT_EXPIRES_IN=
# Optional
JWT_REFRESH_EXPIRES_IN=
# Optional
JWT_INVITE_EXPIRES_IN=
# Optional
JWT_EMAIL_CONFIRMATION_EXPIRES_IN=
# Optional
JWT_PASSWORD_RESET_EXPIRES_IN=
# Optional. Lifetime of the MFA pending token issued between password
# verification and 2FA code entry (default 5m)
JWT_MFA_PENDING_EXPIRES_IN=

# Key for encrypting TOTP secrets at rest (AES-256-GCM). REQUIRED once MFA
# is used. Generate a secure value with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Database
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Subscriptions
# Not relevant for self hosters
SUBSCRIPTIONS_PRICE_PER_SEAT_MONTHLY=
SUBSCRIPTIONS_PRICE_PER_SEAT_YEARLY=

# Trial
# Not relevant for self hosters
TRIAL_MAX_MESSAGES=

# Model Providers (at least one required!)

## Mistral API
MISTRAL_API_KEY=
## Model used for audio transcription; must support the transcription API,
## e.g. voxtral-mini-latest (default) or voxtral-mini-2602
MISTRAL_TRANSCRIPTION_MODEL=
## OpenAI API
OPENAI_API_KEY=
## Anthropic API
ANTHROPIC_API_KEY=
## AWS Bedrock (Anthropic models via AWS)
# Defaults to eu-central-1 when unset (after AWS_REGION / AWS_DEFAULT_REGION)
AWS_BEDROCK_REGION=
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=
## Gemin
GEMINI_API_KEY=
## Ollama Base URL
OLLAMA_BASE_URL=
## Ayunis, not relevant for self hosters
AYUNIS_BASE_URL=
AYUNIS_AUTH_TOKEN=
## OTC API (Open Telekom Cloud)
OTC_API_KEY=
## MS Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
## Scaleway
SCALEWAY_API_KEY=
## STACKIT
STACKIT_TOKEN=
## Synaforce (only used when NODE_ENV=production; falls back to OLLAMA_BASE_URL otherwise)
SYNAFORCE_BASE_URL=

# MinIO (object storage)
# REQUIRED in production: the app refuses to boot without credentials and there
# is no insecure default fallback. Use strong, unique values (do NOT reuse the
# old `minio` / `minio123` defaults). Generate a password with:
#   openssl rand -hex 24
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Optional aliases; default to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD if unset
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_USE_SSL=
MINIO_BUCKET=

# Redis (BullMQ queues)
# REQUIRED in production: Redis must run with authentication. The app refuses to
# boot without REDIS_PASSWORD in production, and the bundled Redis container is
# started with `--requirepass "$REDIS_PASSWORD"`. Generate a value with:
#   openssl rand -hex 32
REDIS_PASSWORD=
# Optional; default to redis:6379 in the bundled docker-compose stack
REDIS_HOST=
REDIS_PORT=

# Internet search
# Provider powering web search: "brave" (default) or "staan" (EU / GDPR).
INTERNET_SEARCH_PROVIDER=brave

# Brave — enables internet search when INTERNET_SEARCH_PROVIDER=brave
BRAVE_SEARCH_URL=
BRAVE_SEARCH_API_KEY=

# Staan (EU provider) — enables internet search when INTERNET_SEARCH_PROVIDER=staan
STAAN_SEARCH_API_KEY=
# Market: de-de (default), en-us, or fr-fr
STAAN_SEARCH_MARKET=de-de
# Optional: override the Staan endpoint (defaults to https://api.staan.ai/v2/search/web).
# Leave unset in normal use — only set it to point at a stub/staging endpoint.
# STAAN_SEARCH_URL=

# MCP (Model Context Protocol)
# Required for MCP integration credential encryption
# Generate a secure key with: openssl rand -hex 32
MCP_ENCRYPTION_KEY=

# Locaboo 4 URL
# Required for Locaboo 4 MCP server integration
# The base URL of the Locaboo 4 instance (e.g., http://localhost:8080 for local development)
# This is used to connect to the Locaboo 4 MCP server for accessing external data sources
LOCABOO_4_URL=

# Marketplace
# URL of the Ayunis Core Marketplace service.
# Used for two things:
#   1) Backend → marketplace HTTP calls (fetching/previewing marketplace skills and integrations).
#   2) Exposed to authenticated frontend users via GET /marketplace/config so the UI can link to
#      the marketplace (sidebar entry and skills-page promo card).
# Only http: and https: URLs are accepted; any other scheme (or an unset value) disables the feature.
# Leave unset to hide the marketplace entry points entirely.
MARKETPLACE_SERVICE_URL=http://localhost:3002

# Metrics
# Basic auth for /metrics endpoint (Prometheus scraping)
AYUNIS_METRICS_USER=prometheus
AYUNIS_METRICS_PASSWORD=changeme

# Runtime
# Optional, 'development' | 'production' | 'test'. Normally set by the process
# manager/runtime, not here. Leave commented — if unset or blank in .env,
# app.config treats NODE_ENV as 'development'.
# NODE_ENV=

# Feature Flags
# Optional toggles, 'true' | 'false'. Leave commented to use the defaults;
# an empty value ("") is treated as the default.
# Enabled by default
# FEATURE_AGENTS_ENABLED=true
# FEATURE_KNOWLEDGE_BASES_ENABLED=true
# FEATURE_PROMPTS_ENABLED=true
# Disabled by default
# FEATURE_SKILLS_ENABLED=false

# Internal Services
# URLs of the companion services (defaults target the local docker compose stack)
# Anonymization service (default http://localhost:8002)
ANONYMIZE_SERVICE_URL=
# Code execution service (default http://localhost:8080)
CODE_EXECUTION_SERVICE_URL=
# Locaboo 4 MCP server URL
LOCABOO_4_MCP_URL=
# Locaboo 3 base URL
LOCABOO3_BASE_URL=

# Source Text Extraction
# Optional limits when reading text from sources
# Max characters returned (default unset)
SOURCE_GET_TEXT_MAX_CHARS=
# Max lines returned (default 200)
SOURCE_GET_TEXT_MAX_LINES=
